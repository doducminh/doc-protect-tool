# ===== doc-protect-tool — cấu hình bảo vệ PDF (mẫu) =====
# Copy file này thành .env rồi chỉnh giá trị cho phù hợp.

# Watermark in mỗi trang (dọc mép phải, ngoài vùng chữ)
WATERMARK=CONFIDENTIAL  —  DO NOT DISTRIBUTE
# Rasterize PDF thành ảnh thuần
RASTER_DPI=300
JPEG_QUALITY=82
# Mật khẩu user (rỗng = mở không cần mật khẩu); owner password sinh ngẫu nhiên rồi huỷ
USER_PASSWORD=
# Metadata mặc định (caller có thể truyền qua argv để ghi đè theo từng sản phẩm)
PDF_TITLE=Technical Handover (CONFIDENTIAL)
PDF_AUTHOR=PSC
PDF_SUBJECT=Project / Source code / Operations handover
